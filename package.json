{
  "name": "monorepo-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "with-env": "dotenv -e .env -- pnpm",
    "dev": "pnpm with-env --parallel --filter './apps/*' --filter @repo/worker dev",
    "build": "pnpm --filter './apps/*' build",
    "test": "pnpm --filter './apps/*' test",
    "test:coverage": "pnpm --filter './apps/*' test:coverage",
    "e2e:install": "playwright install chromium",
    "e2e:prepare": "tsx scripts/e2e/prepare.ts",
    "e2e": "pnpm e2e:prepare && playwright test",
    "e2e:headed": "pnpm e2e:prepare && playwright test --headed",
    "e2e:ui": "pnpm e2e:prepare && playwright test --ui",
    "e2e:report": "playwright show-report",
    "typecheck": "pnpm -r typecheck",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "benchmark:overhead": "tsx scripts/benchmark-overhead.ts",
    "createsuperuser": "dotenv -e .env -- tsx scripts/createsuperuser.ts",
    "db:generate": "pnpm --filter @repo/api db:generate",
    "db:migrate": "pnpm --filter @repo/api db:migrate",
    "db:migrate:deploy": "pnpm --filter @repo/api db:migrate:deploy",
    "db:push": "pnpm --filter @repo/api db:push",
    "db:studio": "pnpm --filter @repo/api db:studio"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@playwright/test": "^1.61.1",
    "@vitest/coverage-v8": "^4.1.9",
    "dotenv-cli": "^11.0.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
