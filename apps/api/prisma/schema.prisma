generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

enum RedemptionCodeStatus {
  ACTIVE
  DISABLED
  USED
}

enum RedemptionTargetType {
  USER
  API_KEY
}

enum ResponsesMode {
  DISABLED
  NATIVE
  VIA_CHAT
}

model User {
  id                            String                  @id @default(cuid())
  email                         String                  @unique
  name                          String?
  passwordHash                  String
  role                          Role                    @default(USER)
  spendLimitUsd                 Float?
  createdAt                     DateTime                @default(now())
  updatedAt                     DateTime                @updatedAt
  apiKeys                       ApiKey[]
  providerKeys                  ProviderKey[]
  providerChannelsCreated       ProviderChannel[]       @relation("ProviderChannelCreator")
  providerChannelsUpdated       ProviderChannel[]       @relation("ProviderChannelUpdater")
  customProviders               CustomProvider[]
  invitationsCreated            Invitation[]            @relation("InvitationCreator")
  invitationsRedeemed           Invitation[]            @relation("InvitationRedeemer")
  invitationRedemptions         InvitationRedemption[]
  redemptionCodesCreated        RedemptionCode[]        @relation("RedemptionCodeCreator")
  redemptionApplicationsApplied RedemptionApplication[] @relation("RedemptionApplicationApplier")
  redemptionApplications        RedemptionApplication[] @relation("RedemptionApplicationUser")
}

model ApiKey {
  id                     String                  @id @default(cuid())
  name                   String
  key                    String                  @unique
  keyCiphertext          String?
  createdBy              String
  creator                User                    @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  isActive               Boolean                 @default(true)
  spendLimitUsd          Float?
  allowAllModels         Boolean                 @default(true)
  includeFutureModels    Boolean                 @default(false)
  allowedModelIds        String[]                @default([])
  invitationId           String?
  invitation             Invitation?             @relation(fields: [invitationId], references: [id], onDelete: SetNull)
  invitationRedemption   InvitationRedemption?
  redemptionApplications RedemptionApplication[]
  createdAt              DateTime                @default(now())
  logs                   RequestLog[]
  backgroundJobs         BackgroundResponseJob[]

  @@index([isActive])
  @@index([invitationId])
}

model RedemptionCode {
  id           String                 @id @default(cuid())
  codeHash     String                 @unique
  codeLastFour String
  name         String
  amountUsd    Float
  status       RedemptionCodeStatus   @default(ACTIVE)
  expiresAt    DateTime?
  createdBy    String
  creator      User                   @relation("RedemptionCodeCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  application  RedemptionApplication?
  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@index([status])
  @@index([createdBy])
  @@index([expiresAt])
}

model RedemptionApplication {
  id               String               @id @default(cuid())
  redemptionCodeId String               @unique
  redemptionCode   RedemptionCode       @relation(fields: [redemptionCodeId], references: [id], onDelete: Cascade)
  targetType       RedemptionTargetType
  userId           String?
  user             User?                @relation("RedemptionApplicationUser", fields: [userId], references: [id], onDelete: SetNull)
  apiKeyId         String?
  apiKey           ApiKey?              @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  appliedBy        String
  applier          User                 @relation("RedemptionApplicationApplier", fields: [appliedBy], references: [id], onDelete: Cascade)
  createdAt        DateTime             @default(now())

  @@index([targetType])
  @@index([userId])
  @@index([apiKeyId])
  @@index([appliedBy])
}

model Invitation {
  id             String                 @id @default(cuid())
  codeHash       String                 @unique
  codeLastFour   String
  balanceUsd     Float?
  isActive       Boolean                @default(true)
  maxRedemptions Int                    @default(1)
  redeemedCount  Int                    @default(0)
  createdBy      String
  creator        User                   @relation("InvitationCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  redeemedBy     String?
  redeemer       User?                  @relation("InvitationRedeemer", fields: [redeemedBy], references: [id], onDelete: SetNull)
  redeemedAt     DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  apiKeys        ApiKey[]
  redemptions    InvitationRedemption[]

  @@index([isActive])
  @@index([createdBy])
  @@index([redeemedBy])
}

model InvitationRedemption {
  id           String     @id @default(cuid())
  invitationId String
  invitation   Invitation @relation(fields: [invitationId], references: [id], onDelete: Cascade)
  userId       String?
  user         User?      @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKeyId     String?    @unique
  apiKey       ApiKey?    @relation(fields: [apiKeyId], references: [id], onDelete: SetNull)
  createdAt    DateTime   @default(now())

  @@index([invitationId])
  @@index([userId])
}

model AppSetting {
  id                        String   @id
  inviteRegistrationEnabled Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt
}

model RequestLog {
  id       String @id @default(cuid())
  apiKeyId String
  apiKey   ApiKey @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  provider       String
  model          String
  requestedModel String?
  channelId      String?
  channelName    String?
  endpoint       String

  latencyMs         Int
  providerLatencyMs Int?

  promptTokens                Int?
  completionTokens            Int?
  totalTokens                 Int?
  reasoningTokens             Int?
  estimatedCost               Float?
  pricingInputTokens          Int?
  appliedInputPricePer1M      Float?
  appliedOutputPricePer1M     Float?
  appliedPricingTierThreshold Int?

  statusCode   Int
  errorMessage String?

  createdAt DateTime @default(now())

  @@index([apiKeyId])
  @@index([provider])
  @@index([channelId])
  @@index([model])
  @@index([createdAt])
}

/// Provider API keys configured for the gateway. Stored encrypted at rest
/// using AES-256-GCM with a key derived from `PROVIDER_KEYS_ENCRYPTION_KEY`.
/// The `provider` field is the primary key (one key per provider).
model ProviderKey {
  provider   String   @id
  /// Base64-encoded ciphertext (IV || authTag || encrypted).
  ciphertext String
  /// Last 4 characters of the plaintext key, for display in the UI only.
  lastFour   String
  updatedBy  String
  updater    User     @relation(fields: [updatedBy], references: [id], onDelete: Cascade)
  updatedAt  DateTime @updatedAt
  createdAt  DateTime @default(now())
}

/// First-class provider channels. A provider can have multiple channels with
/// distinct credentials, model mapping, and OpenAI-compatible request settings.
model ProviderChannel {
  id             String   @id
  provider       String
  name           String
  enabled        Boolean  @default(true)
  priority       Int      @default(0)
  weight         Int      @default(1)
  /// Base64-encoded ciphertext (IV || authTag || encrypted).
  keyCiphertext  String
  /// Last 4 characters of the plaintext key, for display in the UI only.
  lastFour       String
  modelMapping   Json?
  settings       Json?
  otherSettings  Json?
  paramOverride  Json?
  headerOverride Json?
  createdBy      String
  creator        User     @relation("ProviderChannelCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  updatedBy      String
  updater        User     @relation("ProviderChannelUpdater", fields: [updatedBy], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([provider])
  @@index([enabled, priority])
}

model CustomProvider {
  id                String                @id
  name              String
  apiBase           String
  responsesMode     ResponsesMode         @default(DISABLED)
  responsesEndpoint String?
  createdBy         String
  creator           User                  @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  models            CustomProviderModel[]
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt

  @@index([createdBy])
}

model CustomProviderModel {
  providerId       String
  provider         CustomProvider @relation(fields: [providerId], references: [id], onDelete: Cascade)
  modelId          String
  name             String
  inputPricePer1M  Float
  outputPricePer1M Float
  pricingTiers     Json?
  contextWindow    Int
  maxOutputTokens  Int
  inputModalities  String[]
  outputModalities String[]
  reasoning        Boolean
  toolCall         Boolean
  structuredOutput Boolean
  weights          String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@id([providerId, modelId])
}

/// Tracks which models are disabled. A model is enabled by default — presence of
/// a row means the model is disabled. Composite key of (modelId, provider) so
/// enable/disable toggles are idempotent.
model DisabledModel {
  modelId    String
  provider   String
  disabledAt DateTime @default(now())

  @@id([modelId, provider])
}

model FallbackGroup {
  id          String           @id
  name        String
  description String?
  enabled     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  targets     FallbackTarget[]
}

model FallbackTarget {
  id        String        @id @default(cuid())
  groupId   String
  group     FallbackGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  provider  String
  modelId   String
  position  Int
  createdAt DateTime      @default(now())

  @@unique([groupId, position])
  @@index([provider, modelId])
}

model ModelAlias {
  id            String   @id
  name          String
  description   String?
  targetModelId String
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([enabled])
  @@index([targetModelId])
}

/// Tracks background response jobs submitted via POST /v1/responses
/// with background: true. The primary key is the upstream response id
/// (e.g. resp_abc123) returned by the provider, so the row can be
/// looked up directly by client polling on GET /v1/responses/:id.
/// The actual generation is performed server-side by the provider; the
/// worker polls upstream and updates status until the response is terminal.
model BackgroundResponseJob {
  id                 String    @id
  apiKeyId           String
  apiKey             ApiKey    @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  provider           String
  model              String
  channelId          String?
  channelName        String?
  request            Json
  status             String
  response           Json?
  errorMessage       String?
  inputPricePer1M    Float?
  outputPricePer1M   Float?
  pricingTiers       Json?
  upstreamUrl        String?
  spendReservationId String?
  spendReservedUsd   Float?
  spendOwnerId       String?
  createdAt          DateTime  @default(now())
  startedAt          DateTime?
  completedAt        DateTime?

  @@index([apiKeyId])
  @@index([channelId])
  @@index([status])
  @@index([createdAt])
}
