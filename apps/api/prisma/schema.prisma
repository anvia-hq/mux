generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String?
  passwordHash String
  role         Role     @default(USER)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  apiKeys      ApiKey[]
  providerKeys ProviderKey[]
}

model ApiKey {
  id            String   @id @default(cuid())
  name          String
  key           String   @unique
  createdBy     String
  creator       User     @relation(fields: [createdBy], references: [id], onDelete: Cascade)
  isActive      Boolean  @default(true)
  spendLimitUsd Float?
  createdAt     DateTime @default(now())
  logs          RequestLog[]
  backgroundJobs BackgroundResponseJob[]

  @@index([isActive])
}

model RequestLog {
  id                String   @id @default(cuid())
  apiKeyId          String
  apiKey            ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)

  provider          String
  model             String
  endpoint          String

  latencyMs         Int
  providerLatencyMs Int?

  promptTokens      Int?
  completionTokens  Int?
  totalTokens       Int?
  estimatedCost     Float?

  statusCode        Int
  errorMessage      String?

  createdAt         DateTime @default(now())

  @@index([apiKeyId])
  @@index([provider])
  @@index([model])
  @@index([createdAt])
}

/// Provider API keys configured for the gateway. Stored encrypted at rest
/// using AES-256-GCM with a key derived from `PROVIDER_KEYS_ENCRYPTION_KEY`.
/// The `provider` field is the primary key (one key per provider).
model ProviderKey {
  provider    String   @id
  /// Base64-encoded ciphertext (IV || authTag || encrypted).
  ciphertext  String
  /// Last 4 characters of the plaintext key, for display in the UI only.
  lastFour    String
  updatedBy   String
  updater     User     @relation(fields: [updatedBy], references: [id], onDelete: Cascade)
  updatedAt   DateTime @updatedAt
  createdAt   DateTime @default(now())
}

/// Tracks which models are disabled. A model is enabled by default — presence of
/// a row means the model is disabled. Composite key of (modelId, provider) so
/// enable/disable toggles are idempotent.
model DisabledModel {
  modelId    String
  provider   String
  disabledAt DateTime @default(now())

  @@id([modelId, provider])
}

model FallbackGroup {
  id          String           @id
  name        String
  description String?
  enabled     Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  targets     FallbackTarget[]
}

model FallbackTarget {
  id        String        @id @default(cuid())
  groupId   String
  group     FallbackGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  provider  String
  modelId   String
  position  Int
  createdAt DateTime      @default(now())

  @@unique([groupId, position])
  @@index([provider, modelId])
}

/// Tracks background response jobs submitted via POST /v1/responses
/// with background: true. The primary key is the upstream response id
/// (e.g. resp_abc123) returned by the provider, so the row can be
/// looked up directly by client polling on GET /v1/responses/:id.
/// The actual generation is performed server-side by the provider; a
/// future worker (Phase 7.3) will poll upstream and update status.
model BackgroundResponseJob {
  id           String   @id
  apiKeyId     String
  apiKey       ApiKey   @relation(fields: [apiKeyId], references: [id], onDelete: Cascade)
  provider     String
  model        String
  request      Json
  status       String
  response     Json?
  errorMessage String?
  createdAt    DateTime @default(now())
  startedAt    DateTime?
  completedAt  DateTime?

  @@index([apiKeyId])
  @@index([status])
  @@index([createdAt])
}
