DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mux_gateway?schema=public"
REDIS_URL="redis://localhost:6379"
DOCKER_DATABASE_URL="postgresql://postgres:postgres@postgres:5432/mux_gateway?schema=public"
DOCKER_REDIS_URL="redis://redis:6379"
API_PORT="8000"
# When using Caddy, the API is served at /api from the same origin as the platform UI.
# Set this to an absolute URL only if you are not running behind Caddy.
VITE_API_URL="/api"
AUTH_SECRET="dev-change-me"
# Set to true when serving over HTTPS (production / Caddy with TLS).
AUTH_COOKIE_SECURE="false"
# Origins allowed by CORS. When behind Caddy this is typically the public origin.
CLIENT_ORIGINS="http://localhost:3000"

# Caddy reverse proxy
CADDY_DOMAIN="localhost:80"
CADDY_HTTP_PORT="80"
CADDY_HTTPS_PORT="443"

# Encryption key for provider API keys stored in the database.
# Provider keys are set via the dashboard and encrypted at rest with AES-256-GCM.
# Accepts a 64-char hex string or any string (will be SHA-256 hashed).
PROVIDER_KEYS_ENCRYPTION_KEY="dev-encryption-key-change-me"

# Optional local Redis read-through cache for GET /v1/responses/:id.
MUX_RESPONSES_CACHE="0"
MUX_RESPONSES_CACHE_TTL_SECONDS="300"

# Azure Responses API polling for background responses.
# Required only when background jobs target azure-cognitive-services Responses models.
AZURE_OPENAI_RESPONSES_ENDPOINT=""
AZURE_OPENAI_RESPONSES_API_VERSION="2025-04-01-preview"
BACKGROUND_POLL_WORKER_CONCURRENCY="5"

# OpenAI-compatible /v1/chat/completions relay behavior.
# Retryable failures move to the next eligible weighted channel/target.
CHAT_RETRY_COUNT="2"
CHAT_RETRY_STATUS_CODES="408,409,425,429,500-599"
CHAT_FIRST_BYTE_TIMEOUT_MS="60000"
CHAT_STREAM_IDLE_TIMEOUT_MS="60000"
CHAT_NON_STREAM_TIMEOUT_MS="120000"
# Limit applies after gzip/deflate/brotli decompression.
CHAT_MAX_REQUEST_BODY_MB="128"
# Per-API-key fixed-window limits. Both are disabled when set to 0.
CHAT_RATE_LIMIT_WINDOW_SECONDS="60"
CHAT_RATE_LIMIT_TOTAL="0"
CHAT_RATE_LIMIT_SUCCESS="0"

# Overhead benchmark
# Used by `pnpm benchmark:overhead` to compare direct OpenAI calls against Mux.
OPENAI_API_KEY=""
# Preferred: use an existing Mux API key.
MUX_API_KEY=""
# Optional fallback: if MUX_API_KEY is empty, the benchmark can log in as an admin,
# create a temporary Mux API key, then revoke it after the run.
MUX_ADMIN_EMAIL=""
MUX_ADMIN_PASSWORD=""
MUX_BASE_URL="http://localhost"
